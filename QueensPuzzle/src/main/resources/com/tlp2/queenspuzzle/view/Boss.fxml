<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="12" style="-fx-background-color: #f5f0ff; -fx-padding: 18;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/26" fx:controller="com.tlp2.queenspuzzle.controller.BossController">

    <Label style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #7b5ea7;" text="⚔ Desafio Final ⚔" />

    <Label fx:id="labelStatus" style="-fx-text-fill: #9b80c4; -fx-font-size: 12;" text="" wrapText="true" />

    <HBox alignment="CENTER" spacing="30">
        <Label fx:id="labelTempo" style="-fx-text-fill: #7b5ea7; -fx-font-size: 16; -fx-font-weight: bold;" text="Tempo: 45s" />
        <Label fx:id="labelRainhas" style="-fx-text-fill: #ef82db; -fx-font-size: 16; -fx-font-weight: bold;" text="Rainhas: 0/8" />
    </HBox>

    <GridPane fx:id="gridTabuleiro" style="-fx-border-color: #ef82db; -fx-border-width: 3; -fx-border-radius: 4;" />

    <Label fx:id="labelMensagem" style="-fx-font-size: 14; -fx-text-fill: #7b5ea7; -fx-font-weight: bold;" text="" wrapText="true" />

    <HBox alignment="CENTER" spacing="12">
        <Button onAction="#aoClicarLimpar" prefHeight="36" prefWidth="120" style="-fx-background-color: #ede8ff; -fx-text-fill: #7b5ea7; -fx-background-radius: 10; -fx-border-color: #d8b7fe; -fx-border-radius: 10; -fx-border-width: 1; -fx-cursor: hand; -fx-font-weight: bold;" text="🗑 Limpar" />
        <Button onAction="#aoClicarMenu" prefHeight="36" prefWidth="155" style="-fx-background-color: #fcc5fe; -fx-text-fill: #7a1080; -fx-background-radius: 10; -fx-border-color: #e099e8; -fx-border-radius: 10; -fx-border-width: 1.5; -fx-cursor: hand; -fx-font-weight: bold;" text="⬅ Menu Principal" />
    </HBox>

</VBox>

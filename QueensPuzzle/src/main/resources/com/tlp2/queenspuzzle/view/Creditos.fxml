<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.tlp2.queenspuzzle.controller.CreditosController"
      alignment="CENTER" spacing="16"
      style="-fx-background-color: #f5f0ff; -fx-padding: 40;">

    <Label text="♛"
           style="-fx-font-size: 48; -fx-text-fill: #d8b7fe;"/>
    <Label text="Queens Puzzle"
           style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #7b5ea7;"/>

    <!-- Card de créditos -->
    <VBox style="-fx-background-color: white; -fx-padding: 24 32; -fx-background-radius: 16; -fx-border-color: #d8b7fe; -fx-border-width: 1.5; -fx-border-radius: 16;"
          spacing="12" alignment="CENTER">

        <!-- Dupla -->
        <HBox spacing="10" alignment="CENTER">
            <Label text="👥" style="-fx-font-size: 20;"/>
            <VBox alignment="CENTER" spacing="2">
                <Label text="Desenvolvedores" style="-fx-text-fill: #9b80c4; -fx-font-size: 12;"/>
                <Label text="[Nome do Aluno 1]  &amp;  [Nome do Aluno 2]"
                       style="-fx-text-fill: #4a3060; -fx-font-size: 15; -fx-font-weight: bold;"/>
            </VBox>
        </HBox>

        <Separator style="-fx-background-color: #ede8ff;"/>

        <!-- Disciplina -->
        <HBox spacing="10" alignment="CENTER">
            <Label text="📚" style="-fx-font-size: 20;"/>
            <VBox alignment="CENTER" spacing="2">
                <Label text="Disciplina" style="-fx-text-fill: #9b80c4; -fx-font-size: 12;"/>
                <Label text="Programação Orientada a Objetos"
                       style="-fx-text-fill: #4a3060; -fx-font-size: 14;"/>
                <Label text="Instituto Federal de Mato Grosso do Sul"
                       style="-fx-text-fill: #9b80c4; -fx-font-size: 12;"/>
            </VBox>
        </HBox>

        <Separator style="-fx-background-color: #ede8ff;"/>

        <!-- Tecnologias -->
        <HBox spacing="10" alignment="CENTER">
            <Label text="⚙" style="-fx-font-size: 20; -fx-text-fill: #d8b7fe;"/>
            <VBox alignment="CENTER" spacing="4">
                <Label text="Tecnologias utilizadas" style="-fx-text-fill: #9b80c4; -fx-font-size: 12;"/>
                <HBox spacing="8" alignment="CENTER">
                    <Label text="☕ Java 17" style="-fx-text-fill: #7b5ea7; -fx-font-size: 12;"/>
                    <Label text="•" style="-fx-text-fill: #d8b7fe;"/>
                    <Label text="🎨 JavaFX" style="-fx-text-fill: #7b5ea7; -fx-font-size: 12;"/>
                    <Label text="•" style="-fx-text-fill: #d8b7fe;"/>
                    <Label text="🗄 PostgreSQL" style="-fx-text-fill: #7b5ea7; -fx-font-size: 12;"/>
                </HBox>
            </VBox>
        </HBox>

        <Separator style="-fx-background-color: #ede8ff;"/>

        <!-- Sobre o jogo -->
        <HBox spacing="10" alignment="CENTER">
            <Label text="♛" style="-fx-font-size: 20; -fx-text-fill: #ef82db;"/>
            <VBox alignment="CENTER" spacing="3">
                <Label text="Sobre o jogo" style="-fx-text-fill: #9b80c4; -fx-font-size: 12;"/>
                <Label text="Coloque uma rainha por região colorida,"
                       style="-fx-text-fill: #4a3060; -fx-font-size: 12;" wrapText="true" maxWidth="280"/>
                <Label text="sem que nenhuma se toque ou divida linha/coluna."
                       style="-fx-text-fill: #4a3060; -fx-font-size: 12;" wrapText="true" maxWidth="280"/>
            </VBox>
        </HBox>
    </VBox>

    <Button text="↩ Voltar ao Menu" onAction="#aoClicarVoltar"
            prefWidth="180" prefHeight="40"
            style="-fx-background-color: #d8b7fe; -fx-text-fill: #4a2080; -fx-font-size: 14; -fx-background-radius: 12; -fx-border-color: #b088e8; -fx-border-radius: 12; -fx-border-width: 1.5; -fx-cursor: hand;"/>

</VBox>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="16" style="-fx-background-color: #f5f0ff; -fx-padding: 28;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/26" fx:controller="com.tlp2.queenspuzzle.controller.InventarioController">

    <Label style="-fx-font-size: 36;" text="🎒" textFill="#7b5ea7" />
    <Label fx:id="labelTitulo" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #7b5ea7;" text="Inventário" />

    <TextArea fx:id="areaItens" editable="false" prefHeight="200" prefWidth="340" style="-fx-font-size: 13; -fx-background-color: white; -fx-text-fill: #4a3060; -fx-border-color: #d8b7fe; -fx-border-width: 1.5; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10;" />

    <Button onAction="#aoClicarFechar" prefHeight="36" prefWidth="120" style="-fx-background-color: #fcc5fe; -fx-text-fill: #7a1080; -fx-font-weight: bold; -fx-background-radius: 10; -fx-border-color: #e099e8; -fx-border-radius: 10; -fx-border-width: 1.5; -fx-cursor: hand;" text="✕ Fechar" />

</VBox>

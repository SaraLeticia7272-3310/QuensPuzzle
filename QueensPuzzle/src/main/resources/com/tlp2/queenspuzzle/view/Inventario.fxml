<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.tlp2.queenspuzzle.controller.InventarioController"
      alignment="CENTER" spacing="16"
      style="-fx-background-color: #f5f0ff; -fx-padding: 28;">

    <Label text="🎒" style="-fx-font-size: 36;"/>
    <Label fx:id="labelTitulo" text="Inventário"
           style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #7b5ea7;"/>

    <TextArea fx:id="areaItens"
              editable="false" prefWidth="340" prefHeight="200"
              style="-fx-font-size: 13; -fx-background-color: white; -fx-text-fill: #4a3060; -fx-border-color: #d8b7fe; -fx-border-width: 1.5; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10;"/>

    <Button text="✕ Fechar" onAction="#aoClicarFechar"
            prefWidth="120" prefHeight="36"
            style="-fx-background-color: #fcc5fe; -fx-text-fill: #7a1080; -fx-font-weight: bold; -fx-background-radius: 10; -fx-border-color: #e099e8; -fx-border-radius: 10; -fx-border-width: 1.5; -fx-cursor: hand;"/>

</VBox>

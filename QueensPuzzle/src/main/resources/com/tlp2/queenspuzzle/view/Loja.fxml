<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.tlp2.queenspuzzle.controller.LojaController"
      alignment="CENTER" spacing="16"
      style="-fx-background-color: #f5f0ff; -fx-padding: 36;">

    <Label text="🛒 Loja Real"
           style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #7b5ea7;"/>

    <Label fx:id="labelMoedas" text="Suas moedas: 0"
           style="-fx-text-fill: #ef82db; -fx-font-size: 15; -fx-font-weight: bold;"/>

    <!-- Card de itens -->
    <VBox spacing="14"
          style="-fx-background-color: white; -fx-padding: 20 28; -fx-background-radius: 16; -fx-border-color: #d8b7fe; -fx-border-width: 1.5; -fx-border-radius: 16;"
          alignment="CENTER_LEFT">

        <!-- Poção de Tempo -->
        <HBox spacing="14" alignment="CENTER_LEFT">
            <Label text="⏱" style="-fx-font-size: 30;"/>
            <VBox HBox.hgrow="ALWAYS" spacing="2">
                <Label text="Poção de Tempo"
                       style="-fx-text-fill: #4a3060; -fx-font-size: 14; -fx-font-weight: bold;"/>
                <Label text="+30 segundos na próxima run"
                       style="-fx-text-fill: #9b80c4; -fx-font-size: 12;"/>
                <Label text="💰 20 moedas"
                       style="-fx-text-fill: #ef82db; -fx-font-size: 12;"/>
            </VBox>
            <Button text="Comprar" onAction="#aoClicarComprarPocao"
                    style="-fx-background-color: #c9e4ff; -fx-text-fill: #3a6080; -fx-font-weight: bold; -fx-background-radius: 8; -fx-border-color: #7ab8e8; -fx-border-radius: 8; -fx-border-width: 1.5; -fx-cursor: hand;" prefWidth="88"/>
        </HBox>

        <Separator style="-fx-background-color: #ede8ff;"/>

        <!-- Chave de Dica -->
        <HBox spacing="14" alignment="CENTER_LEFT">
            <Label text="🗝" style="-fx-font-size: 30;"/>
            <VBox HBox.hgrow="ALWAYS" spacing="2">
                <Label text="Chave de Dica"
                       style="-fx-text-fill: #4a3060; -fx-font-size: 14; -fx-font-weight: bold;"/>
                <Label text="+1 dica na próxima run"
                       style="-fx-text-fill: #9b80c4; -fx-font-size: 12;"/>
                <Label text="💰 15 moedas"
                       style="-fx-text-fill: #ef82db; -fx-font-size: 12;"/>
            </VBox>
            <Button text="Comprar" onAction="#aoClicarComprarChave"
                    style="-fx-background-color: #d8b7fe; -fx-text-fill: #4a2080; -fx-font-weight: bold; -fx-background-radius: 8; -fx-border-color: #b088e8; -fx-border-radius: 8; -fx-border-width: 1.5; -fx-cursor: hand;" prefWidth="88"/>
        </HBox>

        <Separator style="-fx-background-color: #ede8ff;"/>

        <!-- Amuleto de Pontos -->
        <HBox spacing="14" alignment="CENTER_LEFT">
            <Label text="💎" style="-fx-font-size: 30;"/>
            <VBox HBox.hgrow="ALWAYS" spacing="2">
                <Label text="Amuleto Real"
                       style="-fx-text-fill: #4a3060; -fx-font-size: 14; -fx-font-weight: bold;"/>
                <Label text="+100 pontos bônus por vitória"
                       style="-fx-text-fill: #9b80c4; -fx-font-size: 12;"/>
                <Label text="💰 25 moedas"
                       style="-fx-text-fill: #ef82db; -fx-font-size: 12;"/>
            </VBox>
            <Button text="Comprar" onAction="#aoClicarComprarAmuleto"
                    style="-fx-background-color: #fcc5fe; -fx-text-fill: #7a1080; -fx-font-weight: bold; -fx-background-radius: 8; -fx-border-color: #e099e8; -fx-border-radius: 8; -fx-border-width: 1.5; -fx-cursor: hand;" prefWidth="88"/>
        </HBox>
    </VBox>

    <Label fx:id="labelMensagem" text="" style="-fx-text-fill: #7b5ea7; -fx-font-size: 13;"/>

    <HBox spacing="12" alignment="CENTER">
        <Button text="◀ Voltar ao Jogo" onAction="#aoClicarVoltar"
                prefWidth="155" prefHeight="38"
                style="-fx-background-color: #bbc5ff; -fx-text-fill: #3a2080; -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 10; -fx-border-color: #8b9fe8; -fx-border-radius: 10; -fx-border-width: 1.5; -fx-cursor: hand;"/>
        <Button text="⬆ Upgrades" onAction="#aoClicarUpgrades"
                prefWidth="130" prefHeight="38"
                style="-fx-background-color: #d8b7fe; -fx-text-fill: #4a2080; -fx-background-radius: 10; -fx-border-color: #b088e8; -fx-border-radius: 10; -fx-border-width: 1.5; -fx-cursor: hand;"/>
    </HBox>

</VBox>

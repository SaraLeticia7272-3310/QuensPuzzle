<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="677.0" prefWidth="446.0" spacing="18" style="-fx-background-color: #f5f0ff; -fx-padding: 40;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tlp2.queenspuzzle.controller.MenuPrincipalController">

    <VBox alignment="CENTER" prefHeight="112.0" prefWidth="292.0" spacing="4">
        <Label style="-fx-font-size: 52; -fx-text-fill: #7b5ea7;" text="👑" />
        <Label style="-fx-font-size: 30; -fx-font-weight: bold; -fx-text-fill: #7b5ea7;" text="Queens Puzzle" />
        <Label style="-fx-font-size: 13; -fx-text-fill: #9b80c4; -fx-font-weight: bold;" text="Posicione as rainhas com sabedoria" />
    </VBox>
     <Label style="-fx-text-fill: #7b5ea7; -fx-font-size: 14; -fx-font-weight: bold;" text="Qual é o seu nome?" />
     <TextField fx:id="campoNome" maxWidth="240.0" prefHeight="42.0" prefWidth="210.0" promptText="Digite aqui..." style="-fx-font-size: 14; -fx-background-color: #f5f0ff; -fx-text-fill: #4a3060; -fx-prompt-text-fill: #bba0dd; -fx-padding: 10 14; -fx-background-radius: 10; -fx-border-color: #d8b7fe; -fx-border-radius: 10; -fx-border-width: 1.5;" />

    <Label fx:id="labelMensagem" style="-fx-text-fill: #e74c3c; -fx-font-size: 13; -fx-font-weight: bold;" text="" />

    <VBox alignment="CENTER" spacing="10">
        <Button onAction="#aoClicarJogar" prefHeight="30.0" prefWidth="240" style="-fx-background-color: #bbc5ff; -fx-text-fill: #3a2080; -fx-font-size: 16; -fx-background-radius: 12; -fx-cursor: hand; -fx-border-color: #8b9fe8; -fx-border-radius: 12; -fx-border-width: 1.5; -fx-font-weight: bold;" text="⟫   JOGAR" />

        <Button onAction="#aoClicarRanking" prefHeight="40" prefWidth="240" style="-fx-background-color: #d8b7fe; -fx-text-fill: #4a2080; -fx-font-size: 14; -fx-background-radius: 12; -fx-cursor: hand; -fx-border-color: #b088e8; -fx-border-radius: 12; -fx-border-width: 1.5; -fx-font-weight: bold;" text="🏆   RANKING" />

        <Button onAction="#aoClicarLoja" prefHeight="40" prefWidth="240" style="-fx-background-color: #fcc5fe; -fx-text-fill: #7a1080; -fx-font-size: 14; -fx-background-radius: 12; -fx-cursor: hand; -fx-border-color: #e099e8; -fx-border-radius: 12; -fx-border-width: 1.5; -fx-font-weight: bold;" text="🛒   LOJA" />
        
        <Button onAction="#aoClicarComoJogar" prefHeight="41.0" prefWidth="240" style="-fx-background-color: #bbc5ff; -fx-text-fill: #3a2080; -fx-font-size: 14; -fx-background-radius: 12; -fx-cursor: hand; -fx-border-color: #8b9fe8; -fx-border-radius: 12; -fx-border-width: 1.5; -fx-font-weight: bold;" text="❓  COMO JOGAR" />

        <Button onAction="#aoClicarCreditos" prefHeight="40" prefWidth="240" style="-fx-background-color: #fcc5fe; -fx-text-fill: #7a1080; -fx-font-size: 14; -fx-background-radius: 12; -fx-cursor: hand; -fx-border-color: #e099e8; -fx-border-radius: 12; -fx-border-width: 1.5; -fx-font-weight: bold;" text="📄   CRÉDITOS" />

        <Button onAction="#aoClicarEncerrar" prefHeight="38" prefWidth="240" style="-fx-background-color: #d8b7fe; -fx-font-size: 14; -fx-background-radius: 12; -fx-cursor: hand; -fx-border-color: #b088e8; -fx-border-radius: 12; -fx-border-width: 1.5; -fx-font-weight: bold;" text="✕   ENCERRAR" textFill="#4a2080" />
    </VBox>
   <opaqueInsets>
      <Insets />
   </opaqueInsets>

</VBox>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.tlp2.queenspuzzle.controller.MenuPrincipalController"
      alignment="CENTER" spacing="18"
      style="-fx-background-color: #f5f0ff; -fx-padding: 40;">

    <!-- Título decorativo -->
    <VBox alignment="CENTER" spacing="4">
        <Label text="♛"
               style="-fx-font-size: 52; -fx-text-fill: #d8b7fe;"/>
        <Label text="Queens Puzzle"
               style="-fx-font-size: 30; -fx-font-weight: bold; -fx-text-fill: #7b5ea7;"/>
        <Label text="Posicione as rainhas com sabedoria"
               style="-fx-font-size: 13; -fx-text-fill: #9b80c4;"/>
    </VBox>

    <!-- Card do campo de nome -->
    <VBox alignment="CENTER" spacing="10"
          style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 20 30 20 30; -fx-effect: dropshadow(gaussian, #d8b7fe, 8, 0.2, 0, 2);">
        <Label text="Qual é o seu nome?" style="-fx-text-fill: #7b5ea7; -fx-font-size: 14; -fx-font-weight: bold;"/>
        <TextField fx:id="campoNome" promptText="Digite aqui..."
                   maxWidth="260"
                   style="-fx-font-size: 14; -fx-background-color: #f5f0ff; -fx-text-fill: #4a3060; -fx-prompt-text-fill: #bba0dd; -fx-padding: 10 14; -fx-background-radius: 10; -fx-border-color: #d8b7fe; -fx-border-radius: 10; -fx-border-width: 1.5;"/>
        <Label fx:id="labelMensagem" text="" style="-fx-text-fill: #c050b0; -fx-font-size: 12;"/>
    </VBox>

    <!-- Botões do menu -->
    <VBox alignment="CENTER" spacing="10">
        <Button text="▶   JOGAR" onAction="#aoClicarJogar"
                prefWidth="240" prefHeight="46"
                style="-fx-background-color: #bbc5ff; -fx-text-fill: #3a2080; -fx-font-size: 16; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand; -fx-border-color: #8b9fe8; -fx-border-radius: 12; -fx-border-width: 1.5;"/>

        <Button text="🏆   RANKING" onAction="#aoClicarRanking"
                prefWidth="240" prefHeight="40"
                style="-fx-background-color: #d8b7fe; -fx-text-fill: #4a2080; -fx-font-size: 14; -fx-background-radius: 12; -fx-cursor: hand; -fx-border-color: #b088e8; -fx-border-radius: 12; -fx-border-width: 1.5;"/>

        <Button text="✨   CRÉDITOS" onAction="#aoClicarCreditos"
                prefWidth="240" prefHeight="40"
                style="-fx-background-color: #fcc5fe; -fx-text-fill: #7a1080; -fx-font-size: 14; -fx-background-radius: 12; -fx-cursor: hand; -fx-border-color: #e099e8; -fx-border-radius: 12; -fx-border-width: 1.5;"/>

        <Button text="✕   ENCERRAR" onAction="#aoClicarEncerrar"
                prefWidth="240" prefHeight="38"
                style="-fx-background-color: #f0e8ff; -fx-text-fill: #9b80c4; -fx-font-size: 13; -fx-background-radius: 12; -fx-cursor: hand; -fx-border-color: #d8b7fe; -fx-border-radius: 12; -fx-border-width: 1;"/>
    </VBox>

</VBox>

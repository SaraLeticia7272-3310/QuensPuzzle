<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.tlp2.queenspuzzle.controller.UpgradesController"
      alignment="CENTER" spacing="20"
      style="-fx-background-color: #1a1a2e; -fx-padding: 40;">

    <Label text="⬆ UPGRADES PERMANENTES"
           style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #f0d060;"/>

    <Label fx:id="labelNome" text="Jogador: " style="-fx-text-fill: white; -fx-font-size: 14;"/>
    <Label fx:id="labelPontosDisponiveis" text="Pontos disponíveis: 0"
           style="-fx-text-fill: #2ecc71; -fx-font-size: 16; -fx-font-weight: bold;"/>

    <Separator prefWidth="400" style="-fx-background-color: #444;"/>

    <!-- Upgrades disponíveis -->
    <VBox spacing="15" style="-fx-background-color: #2d2d44; -fx-padding: 20; -fx-background-radius: 10;" alignment="CENTER">

        <!-- Dica extra -->
        <HBox spacing="20" alignment="CENTER">
            <VBox>
                <Label fx:id="labelDicas" text="Dicas extras: 0" style="-fx-text-fill: white; -fx-font-size: 13;"/>
                <Label text="Permite usar mais dicas por run" style="-fx-text-fill: #888; -fx-font-size: 11;"/>
            </VBox>
            <Button text="Comprar" onAction="#aoClicarComprarDica"
                    style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" prefWidth="100"/>
        </HBox>

        <Separator prefWidth="380"/>

        <!-- Tempo bônus -->
        <HBox spacing="20" alignment="CENTER">
            <VBox>
                <Label fx:id="labelTempo" text="Tempo bônus: +0s" style="-fx-text-fill: white; -fx-font-size: 13;"/>
                <Label text="+15 segundos por run" style="-fx-text-fill: #888; -fx-font-size: 11;"/>
            </VBox>
            <Button text="Comprar" onAction="#aoClicarComprarTempo"
                    style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" prefWidth="100"/>
        </HBox>

        <Separator prefWidth="380"/>

        <!-- Pontos bônus -->
        <HBox spacing="20" alignment="CENTER">
            <VBox>
                <Label fx:id="labelPontosBonus" text="Bônus de pontos: +0" style="-fx-text-fill: white; -fx-font-size: 13;"/>
                <Label text="+50 pontos por vitória" style="-fx-text-fill: #888; -fx-font-size: 11;"/>
            </VBox>
            <Button text="Comprar" onAction="#aoClicarComprarPontos"
                    style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" prefWidth="100"/>
        </HBox>
    </VBox>

    <Label fx:id="labelMensagem" text="" style="-fx-text-fill: #2ecc71; -fx-font-size: 13;"/>
    <Label fx:id="labelProximoNivel" text="" style="-fx-text-fill: #f0d060; -fx-font-size: 13;"/>

    <HBox spacing="15" alignment="CENTER">
        <Button text="▶ Jogar Novamente" onAction="#aoClicarJogarNovamente"
                prefWidth="200" prefHeight="42"
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 15; -fx-font-weight: bold; -fx-cursor: hand;"/>

        <Button text="🛒 Loja" onAction="#aoClicarLoja"
                prefWidth="120" prefHeight="42"
                style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-font-size: 14; -fx-cursor: hand;"/>

        <Button text="Menu" onAction="#aoClicarMenu"
                prefWidth="100" prefHeight="42"
                style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-cursor: hand;"/>
    </HBox>

</VBox>

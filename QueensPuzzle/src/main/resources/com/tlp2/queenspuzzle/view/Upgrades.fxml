<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="16" style="-fx-background-color: #f5f0ff; -fx-padding: 36;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tlp2.queenspuzzle.controller.UpgradesController">

    <Label style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #7b5ea7;" text="⬆ Upgrades Permanentes" />

    <Label fx:id="labelNome" style="-fx-text-fill: #9b80c4; -fx-font-size: 13; -fx-font-weight: bold;" text="Jogador: " />

    <Label fx:id="labelPontosDisponiveis" style="-fx-text-fill: #7b5ea7; -fx-font-size: 16; -fx-font-weight: bold;" text="Pontos disponíveis: 0" />

    <!-- Card de upgrades -->
    <VBox alignment="CENTER" spacing="12" style="-fx-background-color: white; -fx-padding: 20 28; -fx-background-radius: 16; -fx-border-color: #d8b7fe; -fx-border-width: 1.5; -fx-border-radius: 16;">

        <!-- Dica extra -->
        <HBox alignment="CENTER" spacing="16">
            <Label style="-fx-font-size: 26;" text="💡" textFill="#4a3060" />
            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Label fx:id="labelDicas" style="-fx-text-fill: #4a3060; -fx-font-size: 13; -fx-font-weight: bold;" text="Dicas extras: 0" />
                <Label style="-fx-text-fill: #9b80c4; -fx-font-size: 11; -fx-font-weight: bold;" text="+1 dica por run — custo: 200 pts" />
            </VBox>
            <Button onAction="#aoClicarComprarDica" prefWidth="90" style="-fx-background-color: #fcc5fe; -fx-text-fill: #7a1080; -fx-font-weight: bold; -fx-background-radius: 8; -fx-border-color: #e099e8; -fx-border-radius: 8; -fx-border-width: 1.5; -fx-cursor: hand;" text="Comprar" />
        </HBox>

        <Separator style="-fx-background-color: #d8b7fe;" />

        <!-- Tempo bônus -->
        <HBox alignment="CENTER" spacing="16">
            <Label style="-fx-font-size: 26;" text="🕛" textFill="#4a3060" />
            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Label fx:id="labelTempo" style="-fx-text-fill: #4a3060; -fx-font-size: 13; -fx-font-weight: bold;" text="Tempo bônus: +0s" />
                <Label style="-fx-text-fill: #9b80c4; -fx-font-size: 11; -fx-font-weight: bold;" text="+15s por run — custo: 150 pts" />
            </VBox>
            <Button onAction="#aoClicarComprarTempo" prefWidth="90" style="-fx-background-color: #bbc5ff; -fx-text-fill: #3a2080; -fx-font-weight: bold; -fx-background-radius: 8; -fx-border-color: #8b9fe8; -fx-border-radius: 8; -fx-border-width: 1.5; -fx-cursor: hand;" text="Comprar" />
        </HBox>

        <Separator style="-fx-background-color: #d8b7fe;" />

        <!-- Pontos bônus -->
        <HBox alignment="CENTER" spacing="16">
            <Label style="-fx-font-size: 26;" text="🌟" textFill="#4a3060" />
            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Label fx:id="labelPontosBonus" style="-fx-text-fill: #4a3060; -fx-font-size: 13; -fx-font-weight: bold;" text="Bônus de pontos: +0" />
                <Label style="-fx-text-fill: #9b80c4; -fx-font-size: 11; -fx-font-weight: bold;" text="+50 pts por vitória — custo: 100 pts" />
            </VBox>
            <Button onAction="#aoClicarComprarPontos" prefWidth="90" style="-fx-background-color: #d8b7fe; -fx-text-fill: #4a2080; -fx-font-weight: bold; -fx-background-radius: 8; -fx-border-color: #b088e8; -fx-border-radius: 8; -fx-border-width: 1.5; -fx-cursor: hand;" text="Comprar" />
        </HBox>
    </VBox>

    <Label fx:id="labelMensagem" style="-fx-text-fill: #7b5ea7; -fx-font-size: 13;" text="" />
    <Label fx:id="labelProximoNivel" style="-fx-text-fill: #9b80c4; -fx-font-size: 12;" text="" />

    <HBox alignment="CENTER" spacing="12">
        <Button onAction="#aoClicarJogarNovamente" prefHeight="42" prefWidth="123.0" style="-fx-background-color: #bbc5ff; -fx-text-fill: #3a2080; -fx-font-size: 15; -fx-font-weight: bold; -fx-background-radius: 12; -fx-border-color: #8b9fe8; -fx-border-radius: 12; -fx-border-width: 1.5; -fx-cursor: hand;" text="Jogar " />

        <Button onAction="#aoClicarLoja" prefHeight="42" prefWidth="110" style="-fx-background-color: #fcc5fe; -fx-text-fill: #7a1080; -fx-font-size: 14; -fx-background-radius: 12; -fx-border-color: #e099e8; -fx-border-radius: 12; -fx-border-width: 1.5; -fx-cursor: hand; -fx-font-weight: bold;" text="🛒 Loja" />

        <Button onAction="#aoClicarMenu" prefHeight="42" prefWidth="90" style="-fx-background-color: #dbcafa; -fx-text-fill: #6a3dbf; -fx-background-radius: 12; -fx-border-color: #a785e6; -fx-border-radius: 12; -fx-border-width: 1; -fx-cursor: hand; -fx-font-weight: bold;" text="Menu" />
    </HBox>

</VBox>
